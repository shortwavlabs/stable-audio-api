HF_TOKEN=hf_your_token_here
STABLE_AUDIO_DEFAULT_MODEL=small-sfx
STABLE_AUDIO_PRELOAD_MODELS=small-sfx
STABLE_AUDIO_DEVICE=cpu
STABLE_AUDIO_MODEL_HALF=true
STABLE_AUDIO_MAX_DURATION=380
STABLE_AUDIO_MAX_STEPS=50

# Job output storage. Leave bucket unset for local ./outputs storage.
STABLE_AUDIO_OUTPUT_DIR=outputs
# STABLE_AUDIO_STORAGE_BUCKET=your-bucket
# STABLE_AUDIO_STORAGE_PREFIX=stable-audio/jobs
# STABLE_AUDIO_STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# STABLE_AUDIO_STORAGE_REGION=auto
# STABLE_AUDIO_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
# STABLE_AUDIO_PRESIGNED_URL_EXPIRES=3600
